# Copy to .env for local development. Do NOT commit real secrets.

# Prisma datasource. SQLite for dev; a Postgres/MySQL URL in production.
DATABASE_URL="file:dev.sqlite"

# 32-byte secret for AES-256-GCM encryption of the Brevo BYOK API key (hex or base64).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace-with-64-hex-characters"

# Provided by the Shopify CLI during `shopify app dev`; set explicitly in production hosting:
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_APP_URL=
# SCOPES=read_customers,read_orders
